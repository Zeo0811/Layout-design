{
  "manifest_version": 3,
  "name": "十字路口排版专用",
  "version": "1.4.5",
  "description": "将Notion/飞书文档自动排版转换为微信公众号格式，支持图片Base64、表格、一键复制",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "https://*.notion.so/*",
    "https://*.notion.site/*",
    "https://*.feishu.cn/*",
    "https://*.larksuite.com/*",
    "https://*.amazonaws.com/*",
    "https://*.feishucdn.com/*",
    "https://*.byteimg.com/*",
    "https://*.larksuitecdn.com/*",
    "https://*.cloudfront.net/*",
    "https://*.bytescm.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.notion.so/*",
        "https://*.notion.site/*",
        "https://*.feishu.cn/*",
        "https://*.larksuite.com/*"
      ],
      "js": [
        "content/notion-parser.js",
        "content/feishu-parser.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
